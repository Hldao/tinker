# Tinker server 环境变量
#
# 复制为 .env 后填上实际值。.env 已在 .gitignore 中。
# 在生产环境直接通过 docker / systemd 注入即可。

# ============================================
# 基础
# ============================================

# 端口 (Railway/Render 会自动注入)
PORT=8788

# 环境 (development / production)
NODE_ENV=development

# 日志级别 (trace / debug / info / warn / error / fatal)
LOG_LEVEL=info

# ============================================
# CORS
# ============================================

# 允许的前端 origin · 多个用逗号分隔
# 开发: http://localhost:8788
# 生产: https://tinkers.ink,https://yourdomain.com
# 留空 = 允许所有 (alpha 期 OK · 生产收紧)
CORS_ORIGINS=

# ============================================
# Rate limiting
# ============================================

# /api/action 每 IP 每分钟最多请求
RATE_LIMIT_ACTION=60

# /api/state 每 IP 每分钟最多请求
RATE_LIMIT_STATE=300

# ============================================
# 数据
# ============================================

# data.json 路径 (默认 ./data.json)
# 容器化部署时挂 volume 到这里
# DATA_FILE=/data/tinker/data.json

# ============================================
# 后期扩展 (V2)
# ============================================

# AUTH_SECRET=...                   # OAuth session 签名
# DATABASE_URL=postgresql://...     # PG 迁移时用
# SENTRY_DSN=...                    # 错误追踪
